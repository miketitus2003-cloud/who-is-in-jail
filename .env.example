# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real keys.

# ── Socrata App Tokens ────────────────────────────────────────────────────────
# Free at each data portal — sign up, create an app token, paste below.
# Without tokens: 1,000 rows/request max. With tokens: 50,000.
NYC_APP_TOKEN=your_nyc_token_here
LA_APP_TOKEN=your_la_token_here
DC_APP_TOKEN=your_dc_token_here
MD_APP_TOKEN=your_md_token_here

# ── US Census API Key ─────────────────────────────────────────────────────────
# Free at api.census.gov/sign-up.html — instant approval
CENSUS_API_KEY=your_census_key_here

# ── PII Salt ──────────────────────────────────────────────────────────────────
# Generate once: python -c "import secrets; print(secrets.token_hex(32))"
# Store it. If you change it, hashes change and cross-booking linkage breaks.
# Never share it. Never commit it.
PII_SALT=generate_a_random_value_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jail_data
DB_USER=postgres
DB_PASSWORD=your_password_here
